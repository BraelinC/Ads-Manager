#!/bin/bash
# meta-ads - CLI for Meta (Facebook) Ads API
# Usage: meta-ads <command> [options]

set -e

# Config from env or defaults
TOKEN="${META_ACCESS_TOKEN:-}"
ACCOUNT="${META_AD_ACCOUNT_ID:-}"
API="https://graph.facebook.com/v21.0"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${GREEN}✓${NC} $1"; }
err() { echo -e "${RED}✗${NC} $1" >&2; exit 1; }
info() { echo -e "${CYAN}→${NC} $1"; }

# Check required env vars
[[ -z "$TOKEN" ]] && err "Set META_ACCESS_TOKEN environment variable"
[[ -z "$ACCOUNT" ]] && err "Set META_AD_ACCOUNT_ID environment variable"

# Helper: GET request
api_get() {
  local path="$1"
  shift
  curl -s -G "$API/$path" \
    --data-urlencode "access_token=$TOKEN" \
    "$@"
}

# Helper: POST request
api_post() {
  local path="$1"
  shift
  curl -s -X POST "$API/$path" \
    -d "access_token=$TOKEN" \
    "$@"
}

# Helper: Format JSON output
pretty() {
  if command -v jq &> /dev/null; then
    jq -r "$@"
  else
    cat
  fi
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_help() {
  cat << 'EOF'
meta-ads - CLI for Meta (Facebook) Ads API

USAGE:
  meta-ads <command> [options]

COMMANDS:
  campaigns                List all campaigns
  adsets [campaign_id]     List ad sets (optionally filter by campaign)
  ads [adset_id]           List ads (optionally filter by ad set)
  audiences                List custom audiences

  insights [level] [opts]  Get performance insights
                           level: account, campaign, adset, ad
                           opts: --days=7, --breakdown=age,gender

  create-campaign <name> <objective>
                           Create campaign (PAUSED by default)
                           objectives: OUTCOME_SALES, OUTCOME_LEADS, OUTCOME_TRAFFIC, etc.

  pause <id>               Pause a campaign/adset/ad
  activate <id>            Activate a campaign/adset/ad

  budget <campaign_id> <daily_cents>
                           Set daily budget (in cents, e.g. 5000 = $50)

  raw <path> [params]      Raw API call (for advanced use)

EXAMPLES:
  meta-ads campaigns
  meta-ads insights campaign --days=30
  meta-ads insights account --breakdown=age,gender
  meta-ads create-campaign "Summer Sale" OUTCOME_SALES
  meta-ads pause 123456789
  meta-ads budget 123456789 5000

ENVIRONMENT:
  META_ACCESS_TOKEN    Your Meta API access token (required)
  META_AD_ACCOUNT_ID   Your ad account ID, e.g. act_123456 (required)
EOF
}

cmd_campaigns() {
  info "Fetching campaigns..."
  api_get "$ACCOUNT/campaigns" \
    --data-urlencode "fields=id,name,status,objective,daily_budget,lifetime_budget" \
    --data-urlencode "limit=50" | pretty '
.data[] | "[\(.status)] \(.name)
  ID: \(.id)
  Objective: \(.objective)
  Budget: \(.daily_budget // .lifetime_budget // "Not set")
"'
}

cmd_adsets() {
  local campaign_id="$1"
  local path="${campaign_id:-$ACCOUNT}/adsets"

  info "Fetching ad sets..."
  api_get "$path" \
    --data-urlencode "fields=id,name,status,campaign_id,daily_budget,optimization_goal,targeting" \
    --data-urlencode "limit=50" | pretty '
.data[] | "[\(.status)] \(.name)
  ID: \(.id)
  Campaign: \(.campaign_id)
  Budget: \(.daily_budget // "Not set")
  Goal: \(.optimization_goal)
"'
}

cmd_ads() {
  local adset_id="$1"
  local path="${adset_id:-$ACCOUNT}/ads"

  info "Fetching ads..."
  api_get "$path" \
    --data-urlencode "fields=id,name,status,adset_id,campaign_id" \
    --data-urlencode "limit=50" | pretty '
.data[] | "[\(.status)] \(.name)
  ID: \(.id)
  Ad Set: \(.adset_id)
  Campaign: \(.campaign_id)
"'
}

cmd_audiences() {
  info "Fetching custom audiences..."
  api_get "$ACCOUNT/customaudiences" \
    --data-urlencode "fields=id,name,subtype,approximate_count,delivery_status" \
    --data-urlencode "limit=50" | pretty '
.data[] | "\(.name)
  ID: \(.id)
  Type: \(.subtype)
  Size: ~\(.approximate_count // "unknown")
"'
}

cmd_insights() {
  local level="${1:-account}"
  shift || true

  local days=7
  local breakdown=""
  local id=""

  # Parse options
  for arg in "$@"; do
    case $arg in
      --days=*) days="${arg#*=}" ;;
      --breakdown=*) breakdown="${arg#*=}" ;;
      --id=*) id="${arg#*=}" ;;
      *) [[ -z "$id" ]] && id="$arg" ;;
    esac
  done

  local path="${id:-$ACCOUNT}/insights"
  local fields="spend,impressions,clicks,cpc,cpm,ctr,reach,frequency,actions,cost_per_action_type,purchase_roas"

  info "Fetching $level insights (last $days days)..."

  local params=(
    --data-urlencode "fields=$fields"
    --data-urlencode "date_preset=last_${days}d"
    --data-urlencode "level=$level"
  )

  [[ -n "$breakdown" ]] && params+=(--data-urlencode "breakdowns=$breakdown")

  api_get "$path" "${params[@]}" | pretty '
.data[] | "
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
\(.campaign_name // .adset_name // .ad_name // "Account")
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Spend:       $\(.spend)
Impressions: \(.impressions)
Clicks:      \(.clicks)
CPC:         $\(.cpc)
CPM:         $\(.cpm)
CTR:         \(.ctr)%
Reach:       \(.reach)
Frequency:   \(.frequency)
Period:      \(.date_start) to \(.date_stop)
"'
}

cmd_create_campaign() {
  local name="$1"
  local objective="$2"

  [[ -z "$name" ]] && err "Usage: meta-ads create-campaign <name> <objective>"
  [[ -z "$objective" ]] && err "Usage: meta-ads create-campaign <name> <objective>"

  info "Creating campaign: $name"
  api_post "$ACCOUNT/campaigns" \
    -d "name=$name" \
    -d "objective=$objective" \
    -d "status=PAUSED" \
    -d "special_ad_categories=[]" | pretty '
"Campaign created!
  ID: \(.id)
  Name: '"$name"'
  Status: PAUSED"'
}

cmd_pause() {
  local id="$1"
  [[ -z "$id" ]] && err "Usage: meta-ads pause <id>"

  info "Pausing $id..."
  api_post "$id" -d "status=PAUSED" | pretty '"Paused: \(.success // "done")"'
}

cmd_activate() {
  local id="$1"
  [[ -z "$id" ]] && err "Usage: meta-ads activate <id>"

  info "Activating $id..."
  api_post "$id" -d "status=ACTIVE" | pretty '"Activated: \(.success // "done")"'
}

cmd_budget() {
  local campaign_id="$1"
  local budget="$2"

  [[ -z "$campaign_id" ]] && err "Usage: meta-ads budget <campaign_id> <daily_cents>"
  [[ -z "$budget" ]] && err "Usage: meta-ads budget <campaign_id> <daily_cents>"

  info "Setting budget for $campaign_id to $budget cents..."
  api_post "$campaign_id" -d "daily_budget=$budget" | pretty '"Budget updated: \(.success // "done")"'
}

cmd_raw() {
  local path="$1"
  shift || true

  [[ -z "$path" ]] && err "Usage: meta-ads raw <path> [curl params]"

  api_get "$path" "$@" | pretty '.'
}

# ─── Main ────────────────────────────────────────────────────────────────────

case "${1:-help}" in
  help|--help|-h)     cmd_help ;;
  campaigns)          cmd_campaigns ;;
  adsets)             cmd_adsets "$2" ;;
  ads)                cmd_ads "$2" ;;
  audiences)          cmd_audiences ;;
  insights)           shift; cmd_insights "$@" ;;
  create-campaign)    cmd_create_campaign "$2" "$3" ;;
  pause)              cmd_pause "$2" ;;
  activate)           cmd_activate "$2" ;;
  budget)             cmd_budget "$2" "$3" ;;
  raw)                shift; cmd_raw "$@" ;;
  *)                  err "Unknown command: $1. Run 'meta-ads help' for usage." ;;
esac
