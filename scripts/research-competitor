#!/bin/bash
# research-competitor - Full competitor research pipeline
# Usage: research-competitor https://facebook.com/pagename

set -e

APIFY_TOKEN="${APIFY_TOKEN:-}"
CONVEX_URL="${CONVEX_URL:-https://formal-weasel-180.convex.cloud}"
APIFY_API="https://api.apify.com/v2"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log() { echo -e "${GREEN}[✓]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
err() { echo -e "${RED}[✗]${NC} $1"; exit 1; }

# Check token
[[ -z "$APIFY_TOKEN" ]] && err "Set APIFY_TOKEN environment variable"

# Check args
[[ -z "$1" ]] && err "Usage: research-competitor <facebook-page-url>"

FB_URL="$1"
PAGE_SLUG=$(echo "$FB_URL" | sed -E 's|.*/([^/?]+)/?.*|\1|')

log "Researching: $PAGE_SLUG"

# Step 1: Scrape Facebook Page
log "Scraping Facebook page info..."
PAGE_RUN=$(curl -s -X POST "$APIFY_API/acts/apify~facebook-pages-scraper/runs?token=$APIFY_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{\"startUrls\": [{\"url\": \"https://www.facebook.com/$PAGE_SLUG/\"}]}")

PAGE_RUN_ID=$(echo "$PAGE_RUN" | jq -r '.data.id')
[[ "$PAGE_RUN_ID" == "null" ]] && err "Failed to start page scraper"

log "Waiting for page scraper (run: $PAGE_RUN_ID)..."
while true; do
  STATUS=$(curl -s "$APIFY_API/actor-runs/$PAGE_RUN_ID?token=$APIFY_TOKEN" | jq -r '.data.status')
  [[ "$STATUS" == "SUCCEEDED" ]] && break
  [[ "$STATUS" == "FAILED" || "$STATUS" == "ABORTED" ]] && err "Page scraper failed: $STATUS"
  sleep 3
done

PAGE_DATASET=$(curl -s "$APIFY_API/actor-runs/$PAGE_RUN_ID?token=$APIFY_TOKEN" | jq -r '.data.defaultDatasetId')
PAGE_DATA=$(curl -s "$APIFY_API/datasets/$PAGE_DATASET/items?token=$APIFY_TOKEN" | jq '.[0]')

# Extract page info
NAME=$(echo "$PAGE_DATA" | jq -r '.title // .name // "Unknown"')
AD_LIBRARY_ID=$(echo "$PAGE_DATA" | jq -r '.pageAdLibrary.id // empty')
LOGO=$(echo "$PAGE_DATA" | jq -r '.profilePictureUrl // empty')
WEBSITE=$(echo "$PAGE_DATA" | jq -r '.website // empty')
INSTAGRAM=$(echo "$PAGE_DATA" | jq -r '.instagram[0].url // empty')
YOUTUBE=$(echo "$PAGE_DATA" | jq -r '.youtube[0].url // empty')
TIKTOK=$(echo "$PAGE_DATA" | jq -r '.tiktok[0].url // empty')

[[ -z "$AD_LIBRARY_ID" ]] && err "Could not find Ad Library ID for this page"

AD_LIBRARY_URL="https://www.facebook.com/ads/library/?active_status=active&ad_type=all&country=US&view_all_page_id=$AD_LIBRARY_ID"

log "Found: $NAME (Ad Library ID: $AD_LIBRARY_ID)"

# Step 2: Create competitor in Convex
log "Creating competitor in Convex..."
TODAY=$(date +%Y-%m-%d)

COMPETITOR_RESULT=$(curl -s -X POST "$CONVEX_URL/api/mutation" \
  -H "Content-Type: application/json" \
  -d "$(jq -n \
    --arg name "$NAME" \
    --arg fbUrl "https://www.facebook.com/$PAGE_SLUG/" \
    --arg fbId "$AD_LIBRARY_ID" \
    --arg adLib "$AD_LIBRARY_URL" \
    --arg website "$WEBSITE" \
    --arg instagram "$INSTAGRAM" \
    --arg youtube "$YOUTUBE" \
    --arg tiktok "$TIKTOK" \
    --arg logo "$LOGO" \
    --arg date "$TODAY" \
    '{
      path: "competitors:create",
      args: {
        name: $name,
        category: "Ad Leader",
        nicheIndustry: "To be categorized",
        description: "Imported via CLI",
        status: "Active",
        facebookPageUrl: $fbUrl,
        facebookPageId: $fbId,
        adLibraryUrl: $adLib,
        website: (if $website == "" then null else $website end),
        instagramUrl: (if $instagram == "" then null else $instagram end),
        youtubeUrl: (if $youtube == "" then null else $youtube end),
        tiktokUrl: (if $tiktok == "" then null else $tiktok end),
        logoUrl: (if $logo == "" then null else $logo end),
        dateAdded: $date
      },
      format: "json"
    }')")

COMPETITOR_ID=$(echo "$COMPETITOR_RESULT" | jq -r '.value // empty')
[[ -z "$COMPETITOR_ID" ]] && err "Failed to create competitor: $COMPETITOR_RESULT"

log "Competitor created: $COMPETITOR_ID"

# Step 3: Scrape ads
log "Scraping ads from Ad Library..."
ADS_RUN=$(curl -s -X POST "$APIFY_API/acts/apify~facebook-ads-scraper/runs?token=$APIFY_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{\"startUrls\": [{\"url\": \"$AD_LIBRARY_URL\"}], \"resultsLimit\": 100}")

ADS_RUN_ID=$(echo "$ADS_RUN" | jq -r '.data.id')
[[ "$ADS_RUN_ID" == "null" ]] && err "Failed to start ads scraper"

log "Waiting for ads scraper (run: $ADS_RUN_ID)..."
while true; do
  STATUS=$(curl -s "$APIFY_API/actor-runs/$ADS_RUN_ID?token=$APIFY_TOKEN" | jq -r '.data.status')
  [[ "$STATUS" == "SUCCEEDED" ]] && break
  [[ "$STATUS" == "FAILED" || "$STATUS" == "ABORTED" ]] && err "Ads scraper failed: $STATUS"
  echo -n "."
  sleep 5
done
echo ""

ADS_DATASET=$(curl -s "$APIFY_API/actor-runs/$ADS_RUN_ID?token=$APIFY_TOKEN" | jq -r '.data.defaultDatasetId')
ADS_DATA=$(curl -s "$APIFY_API/datasets/$ADS_DATASET/items?token=$APIFY_TOKEN")
ADS_COUNT=$(echo "$ADS_DATA" | jq 'length')

log "Found $ADS_COUNT ads"

# Step 4: Transform and upload ads
log "Uploading ads to Convex..."

# Save to temp file for processing
TEMP_FILE="/tmp/ads_$PAGE_SLUG.json"
echo "$ADS_DATA" > "$TEMP_FILE"

# Process ads in batches using Node
node --input-type=module << NODESCRIPT
import { readFileSync } from 'fs';

const CONVEX_URL = "$CONVEX_URL";
const COMPETITOR_ID = "$COMPETITOR_ID";

function calculateDaysRunning(startDate) {
  if (!startDate) return 0;
  const start = new Date(startDate);
  const today = new Date();
  return Math.max(0, Math.floor((today - start) / (1000 * 60 * 60 * 24)));
}

function transformAd(item, position) {
  const startDate = item.start_date || item.startDateFormatted || item.startDate;
  const daysRunning = calculateDaysRunning(startDate);

  const video = item["snapshot.videos"]?.[0] || item.snapshot?.videos?.[0];
  const image = item["snapshot.images"]?.[0] || item.snapshot?.images?.[0];
  const bodyText = item["snapshot.body.text"] || item.snapshot?.body?.text || item.body_text || "No body text";
  const title = item["snapshot.title"] || item.snapshot?.title || item.title;
  const ctaText = item["snapshot.cta_text"] || item.snapshot?.cta_text || item.cta_text;
  const displayFormat = item["snapshot.display_format"] || item.snapshot?.display_format || (video ? "VIDEO" : "IMAGE");
  const linkUrl = item["snapshot.link_url"] || item.snapshot?.link_url || item.link_url;
  const adArchiveId = item.ad_archive_id || item.adArchiveId || \`gen_\${Date.now()}_\${position}\`;

  return {
    competitorId: COMPETITOR_ID,
    adArchiveId: String(adArchiveId),
    adLibraryUrl: item.ad_library_url || item.adLibraryUrl || \`https://www.facebook.com/ads/library/?id=\${adArchiveId}\`,
    headline: title || undefined,
    bodyText: bodyText,
    ctaText: ctaText || undefined,
    displayFormat: displayFormat,
    videoHdUrl: video?.video_hd_url || undefined,
    videoSdUrl: video?.video_sd_url || undefined,
    thumbnailUrl: video?.video_preview_image_url || undefined,
    imageUrl: image?.resized_image_url || image?.original_image_url || undefined,
    landingPageUrl: linkUrl || undefined,
    platforms: item.publisherPlatform || item.publisher_platform || ["FACEBOOK"],
    startDate: startDate ? new Date(startDate).toISOString().split("T")[0] : "2025-01-01",
    isActive: item.isActive ?? item.is_active ?? true,
    isWinner: daysRunning >= 30,
    daysRunning,
    position,
  };
}

async function insertBatch(ads) {
  const response = await fetch(\`\${CONVEX_URL}/api/mutation\`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path: "ads:createMany", args: { ads }, format: "json" })
  });
  return response.ok;
}

const data = JSON.parse(readFileSync("$TEMP_FILE", 'utf8'));
const items = Array.isArray(data) ? data : data.items || [];

console.log(\`Processing \${items.length} ads...\`);

const ads = items.map((item, i) => transformAd(item, i + 1));
const BATCH_SIZE = 5;
let inserted = 0;

for (let i = 0; i < ads.length; i += BATCH_SIZE) {
  const batch = ads.slice(i, i + BATCH_SIZE);
  const ok = await insertBatch(batch);
  if (ok) {
    inserted += batch.length;
    process.stdout.write(\`\r  Inserted \${inserted}/\${ads.length} ads\`);
  }
}
console.log(\`\n✓ Done! Inserted \${inserted} ads\`);
NODESCRIPT

# Cleanup
rm -f "$TEMP_FILE"

# Step 5: Verify
log "Verifying..."
STATS=$(curl -s -X POST "$CONVEX_URL/api/query" \
  -H "Content-Type: application/json" \
  -d '{"path": "ads:getStats", "args": {}}')

echo ""
echo "=============================="
echo "  COMPETITOR RESEARCH COMPLETE"
echo "=============================="
echo "  Name: $NAME"
echo "  Competitor ID: $COMPETITOR_ID"
echo "  Ads imported: $ADS_COUNT"
echo ""
echo "  Stats: $(echo "$STATS" | jq -c '.value')"
echo "=============================="
